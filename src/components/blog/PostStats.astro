---
import slugify from '../../util/slugify';


// Gatsby used HeroIcons. I can use astro-icon if installed or just SVG inlining.
// Assuming astro-icon is not installed (didn't check).
// I will use simple SVG icons for now to avoid dependency hell if not present.

const { date, formattedDate, timeToRead, tags = [] } = Astro.props;
const tagsAvailaible = tags && tags.length > 0;
---

<div class="grid grid-cols-2 gap-2 md:grid-cols-3 lg:grid-cols-1 lg:gap-4 not-prose">
  <div class="flex items-center">
    <svg xmlns="http://www.w3.org/2000/svg" class="mr-3 h-5 w-5 text-zinc-400" viewBox="0 0 20 20" fill="currentColor">
      <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd" />
    </svg>
    <time datetime={date.toString()}>{formattedDate}</time>
  </div>
  <div class="hidden items-center lg:flex">
    <svg xmlns="http://www.w3.org/2000/svg" class="mr-3 h-5 w-5 text-zinc-400" viewBox="0 0 20 20" fill="currentColor">
      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
    </svg>
    {timeToRead} min
  </div>
  {tagsAvailaible && (
    <div class="flex">
        <svg xmlns="http://www.w3.org/2000/svg" class="mr-3 mt-2 h-5 w-5 text-zinc-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M17.707 9.293a1 1 0 010 1.414l-7 7a1 1 0 01-1.414 0l-7-7A.997.997 0 012 10V5a3 3 0 013-3h5c.256 0 .512.098.707.293l7 7zM5 6a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
        </svg>
      <ul class="list-none !pl-0">
        {tags.map((tag, i) => (
          <li class="!m-0 !pl-0 inline">
            <a href={`/blog/tags/${slugify(tag)}`} class="hover:underline">
              {tag}
            </a>
            {i <= tags.length - 2 ? <span> , </span> : null}
          </li>
        ))}

      </ul>
    </div>
  )}
</div>

---
import Layout from '../../layouts/Layout.astro';
import BlogPostList from '../../components/blog/BlogPostList.astro';
import { getCollection } from 'astro:content';
import { BLOG_ID, SITE_URL } from '../../util/jsonld';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// JSON-LD: Blog node listing every post (the page itself is a CollectionPage).
const blogNode = {
  '@type': 'Blog',
  '@id': BLOG_ID,
  name: 'F1 Report Blog',
  description: 'Articles and data stories about Formula 1.',
  url: `${SITE_URL}/blog`,
  blogPost: sortedPosts.map((post) => ({
    '@type': 'BlogPosting',
    headline: post.data.title,
    description: post.data.description,
    datePublished: post.data.date.toISOString(),
    url: `${SITE_URL}/blog/${post.data.slug || post.id}`,
  })),
};
---

<Layout
  title="Blog"
  noMarginTop
  noMarginSides
  noMarginBottom
  jsonLdType="CollectionPage"
  jsonLd={[blogNode]}
>
  <div class="flex flex-grow flex-col items-center">
    <div class="w-full max-w-6xl flex-grow bg-white py-12 shadow">
      <div class="text-center">
        <h1 class="font-yrsa text-4xl font-extrabold leading-9 sm:leading-10 md:text-5xl lg:text-6xl text-slate-900">
          Blog
        </h1>
      </div>
      <BlogPostList blogposts={sortedPosts} />
    </div>
  </div>
</Layout>

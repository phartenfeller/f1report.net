---
import Layout from '../../layouts/Layout.astro';
import ConstructorsTable from '../../components/ConstructorsTable.jsx';
import { getAllTimeConstructorStats } from '../../lib/db';

const stats = getAllTimeConstructorStats();
---

<Layout title="All Constructors">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl font-bold text-slate-900 mb-6">All Constructors</h1>
    
    <div class="bg-white shadow rounded-lg overflow-hidden">
        <ConstructorsTable client:load data={stats} />
    </div>
  </div>
</Layout>

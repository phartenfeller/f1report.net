---
import Layout from '../../layouts/Layout.astro';
import LegacyConstructorsTable from '../../components/LegacyConstructorsTable.jsx';
import { getLegacyConstructorStats } from '../../lib/db';

const stats = getLegacyConstructorStats();
---

<Layout title="All Legacy Constructors">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl font-bold text-slate-900 mb-6">All Legacy Constructor Franchises</h1>
    
    <div class="bg-white shadow rounded-lg overflow-hidden">
        <LegacyConstructorsTable client:load data={stats} />
    </div>
  </div>
</Layout>
